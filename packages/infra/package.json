{
  "name": "@prompt-registry/infra",
  "version": "0.0.1-alpha.1",
  "description": "Infrastructure layer for Prompt Registry - GitHub clients, harvesters, search, and storage",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmadeusITGroup/prompt-registry.git",
    "directory": "packages/infra"
  },
  "keywords": [
    "prompt-registry",
    "infra",
    "github",
    "harvest",
    "search",
    "storage"
  ],
  "author": "Amadeus IT Group",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "copy-templates": "node -e \"const fs=require('fs');fs.mkdirSync('dist/scaffolding',{recursive:true});fs.cpSync('src/scaffolding/templates','dist/scaffolding/templates',{recursive:true,force:true});\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@prompt-registry/core": "workspace:*",
    "axios": "^1.16.1",
    "js-yaml": "^4.2.0",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.41",
    "@types/yauzl": "^2.10.3",
    "@vitest/coverage-v8": "^4.1.7",
    "nock": "^14.0.15",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
