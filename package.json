{
  "name": "prompt-registry-workspace",
  "private": true,
  "description": "pnpm workspace root — orchestrates packages/*, apps/*, lib",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "extension:compile": "pnpm --filter=prompt-registry run compile",
    "extension:package": "pnpm --filter=prompt-registry run package:full",
    "extension:watch": "pnpm --filter=prompt-registry run watch"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^9.39.4",
    "@o3r/eslint-config": "^14.3.2",
    "@o3r/eslint-plugin": "^14.3.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^1.4.1",
    "eslint-plugin-jsdoc": "^61.7.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "jsonc-eslint-parser": "^2.4.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  }
}
